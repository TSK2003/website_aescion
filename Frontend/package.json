{
  "name": "aescion-frontend-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "website",
    "packages/*",
    "packages/config/*"
  ],
  "scripts": {
    "dev": "npm run dev:website",
    "dev:website": "npm run dev --workspace=website",
    "build": "npm run build --workspaces --if-present",
    "build:website": "npm run build --workspace=website",
    "lint": "npm run lint --workspaces",
    "install:all": "npm install"
  },
  "dependencies": {
    "minipass": "^7.1.3"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
