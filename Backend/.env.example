# ==============================================================================
# AESCION ENTERPRISE SOFTWARE ECOSYSTEM
# BACKEND ENVIRONMENT CONFIGURATION
# ==============================================================================

# Database Connection
DATABASE_URL="postgresql://user:password@localhost:5432/aescion_db?schema=public"

# JWT Secrets
JWT_SECRET="generate-a-secure-random-32-byte-string-here"
JWT_REFRESH_SECRET="generate-a-different-secure-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Security
SESSION_SECRET="your-session-secret"

# Initial Super Admin Seeding
SUPER_ADMIN_EMAIL="contact.aescion@gmail.com"
SUPER_ADMIN_PASSWORD="Aescion#@2025"
SUPER_ADMIN_NAME="AESCION SUPER ADMIN"
SUPER_ADMIN_ROLE="Super Admin"

# Application URLs
BACKEND_URL="http://localhost:3001"
ADMIN_URL="http://localhost:3002"
WEBSITE_URL="http://localhost:3000"

# Caching & Queues
REDIS_URL="redis://localhost:6379"

# SMTP / Email Configuration
SMTP_HOST="smtp.mailgun.org"
SMTP_PORT=587
SMTP_USER="postmaster@aescion.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM='"Aescion System" <no-reply@aescion.com>'

# AWS / Cloud Storage (Media Library)
AWS_REGION="us-east-1"
AWS_BUCKET="aescion-media-prod"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
UPLOAD_PATH="./uploads"

# Logging & Monitoring
LOG_LEVEL="info"
APP_NAME="aescion-enterprise-api"
